{
  "name": "energy-scraper",
  "version": "0.5.1",
  "private": true,
  "main": "components/app.js",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "start": "node ./bin/www",
    "dev": "node --watch --env-file=.env ./bin/www",
    "check": "node --check ./bin/www && node --check ./components/app.js && node --check ./components/metrics-runtime.js && node --check ./components/vars.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:live-mqtt": "cross-env RUN_REAL_MQTT_TEST=1 node --test ./test/integration/real-mqtt.test.js",
    "test:watch": "node --test --watch",
    "release:bump:patch": "node ./scripts/bump-version.js patch",
    "release:bump:minor": "node ./scripts/bump-version.js minor",
    "release:bump:major": "node ./scripts/bump-version.js major",
    "release:draft": "node ./scripts/create-release-draft.js"
  },
  "dependencies": {
    "@neurocode.io/k8s-graceful-shutdown": "^1.5.1",
    "debug": "~2.6.9",
    "express": "^5.2.1",
    "http-errors": "~2.0.1",
    "morgan": "^1.10.1",
    "mqtt": "^5.15.0",
    "prom-client": "^15.1.3",
    "pug": "^3.0.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1"
  }
}